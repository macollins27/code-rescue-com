---
import { HOW_IT_WORKS } from "@content/copy";
import { PIPELINE } from "@content/pipeline";
---

<section class="section" id="how">
  <div class="wrap narrow">
    <div class="kicker">{HOW_IT_WORKS.kicker}</div>
    <h2 class="h2">{HOW_IT_WORKS.title}</h2>
    <p class="sub">{HOW_IT_WORKS.sub}</p>
  </div>
  <div class="wrap">
    <ol class="pipeline">
      {
        PIPELINE.map((s) => (
          <li class="pipeline-step">
            <div class="pipeline-num">{s.stage}</div>
            <div class="pipeline-title">{s.title}</div>
            <div class="pipeline-plain">{s.plain}</div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .pipeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .pipeline-step {
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pipeline-num {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-faint);
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border-radius: 50%;
  }
  .pipeline-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.25;
    color: var(--ink);
  }
  .pipeline-plain {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-dim);
  }
</style>
