---
import SectionHead from "./SectionHead.astro";
import { UNSOLVED } from "@content/copy";
---

<section>
  <div class="wrap">
    <SectionHead idx={UNSOLVED.idx} title={UNSOLVED.title} subHtml={UNSOLVED.subHtml} />
    <div class="callout pull">&ldquo;{UNSOLVED.callout}&rdquo;</div>
    <p class="serif dim follow">{UNSOLVED.follow}</p>
  </div>
</section>

<style>
  .pull {
    max-width: 72ch;
    font-size: 22px;
    line-height: 1.4;
  }
  .follow {
    font-size: 16px;
    line-height: 1.6;
    max-width: 62ch;
    margin-top: 20px;
    text-wrap: pretty;
  }
</style>
