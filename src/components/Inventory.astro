---
import SectionHead from "./SectionHead.astro";
import { INVENTORY_SEC } from "@content/copy";
import { INVENTORY } from "@content/inventory";
import LiveGate from "./craft/LiveGate.tsx";
---

<section id="system">
  <div class="wrap">
    <SectionHead idx={INVENTORY_SEC.idx} title={INVENTORY_SEC.title} sub={INVENTORY_SEC.sub} />

    <table class="inv">
      <thead>
        <tr>
          <th>Artifact</th>
          <th class="col-count">Count</th>
          <th>Detail</th>
        </tr>
      </thead>
      <tbody>
        {
          INVENTORY.map(([k, n, d]) => (
            <tr>
              <td>{k}</td>
              <td class="accent num">{n}</td>
              <td>{d}</td>
            </tr>
          ))
        }
      </tbody>
    </table>

    <div class="blocks">
      <div>
        <div class="up faint block-label">Gate command</div>
        <LiveGate client:visible />
        <noscript>
          <pre class="code gate-block">{INVENTORY_SEC.gateCommand}</pre>
        </noscript>
      </div>
      <div>
        <div class="up faint block-label">Explicit command denies</div>
        <pre class="code">{INVENTORY_SEC.denies}</pre>
      </div>
    </div>
  </div>
</section>

<style>
  table.inv {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: 13px;
  }
  table.inv th {
    text-align: left;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 12px 16px;
    border-bottom: 1px solid var(--rule-strong);
  }
  table.inv td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    color: var(--ink);
  }
  table.inv td:first-child {
    color: var(--ink);
    font-weight: 600;
    width: 28%;
  }
  table.inv td:last-child {
    color: var(--ink-dim);
  }
  table.inv tr:hover td {
    background: var(--panel);
  }
  .col-count {
    width: 90px;
  }
  .blocks {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .block-label {
    font-size: 11px;
    margin-bottom: 12px;
  }
  .blocks pre {
    margin: 0;
  }
  @media (max-width: 900px) {
    table.inv td:first-child {
      width: 40%;
    }
    .blocks {
      grid-template-columns: 1fr;
    }
  }
</style>
