---
import { TOPNAV } from "@content/copy";
---

<header class="topnav">
  <div class="wrap topnav-inner">
    <a href="/" class="brand" aria-label="Code-Rescue home">
      <span class="brand-mark">CR</span>
      <span class="brand-name">Code-Rescue</span>
    </a>
    <nav class="topnav-links" aria-label="Primary">
      {TOPNAV.links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={TOPNAV.cta.href} class="topnav-cta">{TOPNAV.cta.label}</a>
    </nav>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(245, 242, 236, 0.88);
    backdrop-filter: saturate(160%) blur(8px);
    -webkit-backdrop-filter: saturate(160%) blur(8px);
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .topnav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: var(--accent-ink);
    font-family: var(--serif);
    font-weight: 700;
    font-size: 14px;
  }
  .brand-name {
    color: var(--ink);
  }
  .topnav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .topnav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-2);
  }
  .topnav-links a:hover {
    color: var(--accent);
  }
  .topnav-cta {
    padding: 8px 16px;
    background: var(--ink);
    color: var(--bg) !important;
    border-radius: 2px;
    transition: all 150ms ease;
  }
  .topnav-cta:hover {
    background: var(--accent);
    color: var(--accent-ink) !important;
  }
  @media (max-width: 640px) {
    .topnav-links {
      gap: 14px;
    }
    .topnav-links a:not(.topnav-cta) {
      display: none;
    }
    .topnav-cta {
      padding: 8px 14px;
      font-size: 13px;
    }
    .brand {
      font-size: 17px;
    }
  }
</style>
