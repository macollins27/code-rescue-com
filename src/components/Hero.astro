---
import { HERO } from "@content/copy";
---

<section class="hero">
  <div class="wrap">
    <div class="eyebrow">
      <span class="dot" aria-hidden="true"></span><span>{HERO.eyebrow}</span>
    </div>
    <h1 set:html={HERO.headlineHtml} />
    <p class="lede">{HERO.lede}</p>
    <div class="thesis">
      <div class="label">{HERO.thesisLabel}</div>
      <div class="q">&ldquo;{HERO.thesisQuote}&rdquo;</div>
      <div class="src">
        — {HERO.thesisSourceName},{" "}
        <a class="link" href={HERO.thesisSourceHref} rel="external">{HERO.thesisSourceLabel}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    border-top: 0;
    padding: 72px 0 56px;
  }
  .eyebrow {
    color: var(--ink-faint);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow .dot {
    width: 8px;
    height: 8px;
    background: var(--accent);
    display: inline-block;
  }
  .hero :global(h1) {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 5.6vw, 78px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 32px 0;
    max-width: 19ch;
    text-wrap: balance;
  }
  .hero :global(h1 em) {
    font-style: italic;
    color: var(--accent);
  }
  .lede {
    font-family: var(--serif);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.5;
    color: var(--ink-dim);
    max-width: 62ch;
    margin-bottom: 44px;
  }
  .thesis {
    border-top: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    padding: 28px 0;
    margin: 32px 0 0;
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 32px;
    align-items: baseline;
  }
  .thesis .label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .thesis .q {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.3;
    max-width: 48ch;
  }
  .thesis .src {
    font-size: 11px;
    color: var(--ink-faint);
  }
  @media (max-width: 900px) {
    .hero {
      padding: 48px 0 32px;
    }
    .thesis {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
