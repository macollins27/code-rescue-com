---
import SectionHead from "./SectionHead.astro";
import { CASES_SEC } from "@content/copy";
import { CASES } from "@content/cases";
---

<section id="cases">
  <div class="wrap">
    <SectionHead idx={CASES_SEC.idx} title={CASES_SEC.title} sub={CASES_SEC.sub} />
    <div>
      {
        CASES.map((c) => (
          <article class="case">
            <div class="meta">
              <span class="num">{c.num}</span>
              <div class="kicker">{c.kicker}</div>
            </div>
            <div>
              <h3>{c.title}</h3>
              <div class="body">
                <p class="case-extra">
                  <span class="lbl">Incident</span>
                  {c.incident}
                </p>
                <p class="case-extra">
                  <span class="lbl">Observation</span>
                  {c.observation}
                </p>
                <p>
                  <span class="lbl">Mechanism</span>
                  {c.mechanism}
                </p>
                {c.code ? (
                  <pre class="code case-extra">
                    <code>{c.code}</code>
                  </pre>
                ) : null}
                <div class="result">
                  <span class="lbl result-lbl">Result</span>
                  <span set:html={c.resultHtml} />
                </div>
                <div class="tags">
                  {c.crises.map((cr) => (
                    <span class="crisis-tag">↳ {cr}</span>
                  ))}
                  {c.essay ? (
                    <a class="link essay" href={`https://maxwellacollins.com${c.essay}`}>
                      Read essay →
                    </a>
                  ) : null}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .case {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 40px;
    padding: 48px 0;
    border-top: 1px solid var(--rule);
  }
  .meta {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .meta .num {
    display: block;
    font-family: var(--mono);
    font-size: 36px;
    color: var(--ink);
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }
  .kicker {
    color: var(--ink-faint);
  }
  h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(22px, 2.2vw, 30px);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 22px;
    max-width: 34ch;
    text-wrap: balance;
  }
  .body {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink);
    max-width: 72ch;
  }
  .body p {
    margin: 0 0 14px;
  }
  .body :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .lbl {
    display: inline-block;
    font-family: var(--mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-right: 8px;
    min-width: 92px;
  }
  .result {
    background: var(--panel);
    border: 1px solid var(--rule);
    padding: 18px 22px;
    margin-top: 18px;
    font-family: var(--serif);
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--ink);
  }
  .result-lbl {
    color: var(--accent);
  }
  .tags {
    margin-top: 18px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .crisis-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 3px 8px;
    border: 1px solid var(--accent);
  }
  .essay {
    margin-left: 10px;
    font-size: 12px;
    font-family: var(--mono);
  }
  @media (max-width: 900px) {
    .case {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 32px 0;
    }
  }
</style>
