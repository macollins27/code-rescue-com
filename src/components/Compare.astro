---
import SectionHead from "./SectionHead.astro";
import { COMPARE } from "@content/copy";
---

<section>
  <div class="wrap">
    <SectionHead idx={COMPARE.idx} title={COMPARE.title} sub={COMPARE.sub} />
    <div class="compare">
      <div class="col">
        <h4>{COMPARE.hire.label}</h4>
        <ul>{COMPARE.hire.bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
      <div class="col right">
        <h4>{COMPARE.engagement.label}</h4>
        <ul>{COMPARE.engagement.bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
    </div>
  </div>
</section>

<style>
  .compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--rule-strong);
  }
  .compare > div {
    padding: 32px 36px;
  }
  .col {
    border-right: 1px solid var(--rule-strong);
  }
  .col.right {
    border-right: 0;
    background: var(--panel);
  }
  h4 {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 20px;
    font-weight: 500;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  li {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    padding: 12px 0;
    border-top: 1px solid var(--rule);
    color: var(--ink);
    text-wrap: pretty;
  }
  li:first-child {
    border-top: 0;
  }
  @media (max-width: 900px) {
    .compare {
      grid-template-columns: 1fr;
    }
    .col {
      border-right: 0;
      border-bottom: 1px solid var(--rule-strong);
    }
  }
</style>
