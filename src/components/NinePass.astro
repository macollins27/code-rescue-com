---
import SectionHead from "./SectionHead.astro";
import { NINE_PASS } from "@content/copy";
import { PASSES } from "@content/passes";
import NinePassInteractive from "./NinePassInteractive.tsx";
---

<section>
  <div class="wrap">
    <SectionHead idx={NINE_PASS.idx} title={NINE_PASS.title} subHtml={NINE_PASS.subHtml} />
    <NinePassInteractive passes={PASSES} client:visible />
  </div>
</section>

<style is:global>
  .passes {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .pass {
    background: var(--panel-2);
    padding: 16px 12px;
    text-align: left;
    cursor: pointer;
    transition: background 120ms;
    border: none;
    color: inherit;
  }
  .pass:hover {
    background: var(--panel);
  }
  .pass.active {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .pass .pn {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.12em;
  }
  .pass.active .pn {
    color: var(--accent-ink);
    opacity: 0.7;
  }
  .pass .pt {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    margin-top: 8px;
    line-height: 1.3;
  }
  .reviewer-state {
    border: 1px solid var(--rule);
    background: var(--panel-2);
    padding: 20px 22px;
    margin-top: 16px;
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.7;
  }
  .reviewer-state .rs-k {
    color: var(--accent);
  }
  .reviewer-state .rs-ok {
    color: var(--ok);
  }
  .reviewer-state .rs-str {
    color: var(--ink-dim);
  }
  @media (max-width: 900px) {
    .passes {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
