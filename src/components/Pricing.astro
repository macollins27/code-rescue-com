---
import { PRICING } from "@content/copy";
import { COMPARE } from "@content/compare";
---

<section class="section" id="pricing">
  <div class="wrap narrow">
    <div class="kicker">{PRICING.kicker}</div>
    <h2 class="h2">{PRICING.title}</h2>
    <p class="sub">{PRICING.sub}</p>

    <div class="price-card">
      <div class="price-floor">
        <span class="price-floor-label">{PRICING.floor.label}</span>
        <span class="price-floor-amount">{PRICING.floor.amount}</span>
        <span class="price-floor-note">{PRICING.floor.note}</span>
      </div>

      <div class="price-scope">
        <div class="price-scope-label">{PRICING.scopeLabel}</div>
        <ul class="price-scope-list">
          {PRICING.scopeFactors.map((f) => <li>{f}</li>)}
        </ul>
      </div>

      <p class="price-reassurance">{PRICING.reassurance}</p>
    </div>

    <div class="alternatives">
      <div class="kicker">{PRICING.alternativesKicker}</div>
      <h3 class="h3">{PRICING.alternativesTitle}</h3>
      <p class="small-sub">{PRICING.alternativesSub}</p>

      <div class="compare-v2">
        {
          COMPARE.map((row) => (
            <div class="compare-v2-row">
              <div class="compare-v2-label">{row.label}</div>
              <div class="compare-v2-cell">
                <span class="compare-v2-k">What it produces</span>
                <span class="compare-v2-v">{row.produces}</span>
              </div>
              <div class="compare-v2-cell">
                <span class="compare-v2-k">What it leaves</span>
                <span class="compare-v2-v">{row.gap}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .price-card {
    margin-top: 40px;
    border: 1px solid var(--line-2);
    background: var(--bg-card);
    padding: 40px;
  }

  .price-floor {
    display: grid;
    grid-template-columns: 120px auto 1fr;
    gap: 32px;
    align-items: baseline;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .price-floor-label {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .price-floor-amount {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(36px, 4.5vw, 48px);
    letter-spacing: -0.02em;
    color: var(--accent-deep);
    line-height: 1;
  }
  .price-floor-note {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .price-scope {
    padding: 32px 0 28px;
    border-bottom: 1px solid var(--line);
  }
  .price-scope-label {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    margin-bottom: 16px;
  }
  .price-scope-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .price-scope-list li {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    padding-left: 20px;
    position: relative;
  }
  .price-scope-list li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .price-reassurance {
    margin: 28px 0 0;
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink);
  }

  .alternatives {
    margin-top: 80px;
  }

  .compare-v2 {
    margin-top: 24px;
    border: 1px solid var(--line-2);
    background: var(--bg-card);
  }
  .compare-v2-row {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1.3fr;
    gap: 32px;
    padding: 28px 32px;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }
  .compare-v2-row:last-child {
    border-bottom: none;
  }
  .compare-v2-label {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.3;
    color: var(--ink);
  }
  .compare-v2-cell {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .compare-v2-k {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .compare-v2-v {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  @media (max-width: 900px) {
    .price-card {
      padding: 28px 24px;
    }
    .price-floor {
      grid-template-columns: 90px 1fr;
      gap: 8px 20px;
      padding-bottom: 24px;
    }
    .price-floor-note {
      grid-column: 2;
    }
    .price-floor-amount {
      font-size: 32px;
    }
    .price-scope {
      padding: 24px 0 22px;
    }
    .compare-v2-row {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 22px 24px;
    }
  }
  @media (max-width: 640px) {
    .price-card {
      padding: 24px 20px;
    }
    .price-floor {
      grid-template-columns: 1fr;
      gap: 4px;
      padding-bottom: 22px;
    }
    .price-floor-note {
      grid-column: 1;
    }
    .price-floor-amount {
      font-size: 36px;
      margin: 4px 0;
    }
    .price-scope-list li {
      font-size: 15px;
    }
    .alternatives {
      margin-top: 56px;
    }
  }
</style>
