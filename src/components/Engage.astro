---
import { ENGAGE } from "@content/copy";
---

<section class="section section-engage" id="engage">
  <div class="wrap narrow">
    <div class="kicker">{ENGAGE.kicker}</div>
    <h2 class="h2">{ENGAGE.title}</h2>
    <p class="sub">{ENGAGE.sub}</p>

    <div class="channels">
      {
        ENGAGE.channels.map((ch) => (
          <a class={`channel${ch.primary ? " channel-primary" : ""}`} href={ch.href}>
            <span class="channel-k">{ch.k}</span>
            <span class="channel-v">{ch.v}</span>
            <span class="channel-arrow" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>

    <dl class="engage-facts">
      {
        ENGAGE.facts.map((f) => (
          <div>
            <dt>{f.k}</dt>
            <dd>{f.v}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .channels {
    margin: 40px 0 0;
    display: grid;
    grid-template-columns: 1.1fr 1fr 1fr;
    gap: 16px;
  }
  .channel {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 4px 16px;
    padding: 24px 28px;
    border: 1px solid rgba(245, 242, 236, 0.3);
    background: rgba(245, 242, 236, 0.05);
    color: var(--accent-ink);
    text-decoration: none;
    transition:
      background 200ms,
      border-color 200ms,
      transform 200ms;
  }
  .channel:hover {
    background: var(--bg);
    color: var(--accent-deep);
    border-color: var(--bg);
    transform: translateY(-2px);
  }
  .channel-primary {
    background: var(--bg);
    color: var(--accent-deep);
    border-color: var(--bg);
  }
  .channel-primary:hover {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .channel-k {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }
  .channel-v {
    grid-column: 1;
    grid-row: 2;
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
  }
  .channel-arrow {
    grid-column: 2;
    grid-row: 1 / -1;
    align-self: center;
    font-family: var(--serif);
    font-size: 28px;
    opacity: 0.5;
    transition:
      transform 200ms,
      opacity 200ms;
  }
  .channel:hover .channel-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .engage-facts {
    margin: 56px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    padding-top: 32px;
    border-top: 1px solid rgba(245, 242, 236, 0.25);
  }
  .engage-facts > div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .engage-facts dt {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(245, 242, 236, 0.55);
  }
  .engage-facts dd {
    margin: 0;
    font-family: var(--serif);
    font-size: 17px;
    color: var(--accent-ink);
  }
  @media (max-width: 900px) {
    .channels {
      grid-template-columns: 1fr;
    }
    .engage-facts {
      grid-template-columns: 1fr 1fr;
      gap: 24px 20px;
    }
  }
  @media (max-width: 640px) {
    .channel {
      padding: 20px 22px;
    }
    .channel-v {
      font-size: 18px;
    }
    .engage-facts {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
</style>
