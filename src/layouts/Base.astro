---
import "@styles/tokens.css";
import "@styles/fonts.css";
import "@styles/global.css";
import { META } from "@content/copy";
import StructuredData from "@components/StructuredData.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = META.title,
  description = META.description,
  canonical = Astro.url.href,
} = Astro.props;

const OG_IMAGE = new URL("/og.png", Astro.site ?? "https://code-rescue.com/").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f5f2ec" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Code-Rescue" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Code-Rescue — install the stack that catches AI mistakes before they ship."
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta
      name="twitter:image:alt"
      content="Code-Rescue — install the stack that catches AI mistakes before they ship."
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <StructuredData />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Maxwell Collins — Field Notes"
      href="https://maxwellacollins.com/feed.xml"
    />
  </head>
  <body>
    <!--
      ── CODE-RESCUE ──────────────────────────────────────────
      You opened view-source. Welcome.

      This page is hand-laid. Markup is canonical HTML5.
      There is no tracking, no analytics, no third-party scripts.
      Fonts are self-hosted. JS ships tiny.

      If you find a bug, email max@code-rescue.com.

      Puzzle: the essay referenced at the hero is dated. What's
      the date? First correct email moves up the waitlist by one slot.
      ─────────────────────────────────────────────────────────
    -->
    <slot />
  </body>
</html>
