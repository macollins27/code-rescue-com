---
import Base from "./Base.astro";
import TopNav from "@components/TopNav.astro";
import SiteFooter from "@components/SiteFooter.astro";

interface Props {
  title: string;
  description: string;
  kicker: string;
  h1: string;
  lastUpdated: string;
}

const { title, description, kicker, h1, lastUpdated } = Astro.props;
---

<Base title={title} description={description}>
  <TopNav />
  <main class="legal-main">
    <div class="wrap narrow">
      <div class="legal-head">
        <div class="kicker">{kicker}</div>
        <h1 class="h2">{h1}</h1>
        <div class="legal-meta">Last updated {lastUpdated}</div>
      </div>
      <div class="prose legal-body">
        <slot />
      </div>
    </div>
  </main>
  <SiteFooter />
</Base>

<style>
  .legal-main {
    padding: 96px 0 120px;
  }
  .legal-head {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .legal-meta {
    margin-top: 16px;
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .legal-body :global(h2) {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 40px 0 12px;
    color: var(--ink);
  }
  .legal-body :global(h2:first-child) {
    margin-top: 0;
  }
  .legal-body :global(p) {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 20px;
    text-wrap: pretty;
  }
  .legal-body :global(ul) {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 20px;
    padding-left: 24px;
  }
  .legal-body :global(li) {
    margin-bottom: 8px;
  }
  .legal-body :global(a) {
    color: var(--accent);
    border-bottom: 1px solid rgba(42, 95, 79, 0.35);
  }
  @media (max-width: 640px) {
    .legal-main {
      padding: 56px 0 80px;
    }
  }
</style>
